# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-random-secret-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Only used when DJANGO_DEBUG=False (production hardening, see settings.py):
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-production-domain.com

# ---------------------------------------------------------------------------
# Database - Neon (Postgres). Get this from your Neon project dashboard:
# https://console.neon.tech -> Project -> Connection Details -> "Pooled connection"
# Format: postgres://<user>:<password>@<host>/<dbname>?sslmode=require
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://user:password@ep-xxxx-pooler.region.aws.neon.tech/patternvault?sslmode=require

# ---------------------------------------------------------------------------
# LLM (OpenRouter) - https://openrouter.ai/keys
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ---------------------------------------------------------------------------
# Judge0 (self-hosted via docker-compose, see repo root docker-compose.yml)
# JUDGE0_AUTH_TOKEN must match AUTHN_TOKEN in judge0.conf at the repo root —
# this locks down the sandbox so only this backend can submit code to it.
# ---------------------------------------------------------------------------
JUDGE0_API_URL=http://localhost:2358
JUDGE0_AUTH_TOKEN=change-me-judge0-shared-secret

# ---------------------------------------------------------------------------
# CodeChef developer API - register at https://developers.codechef.com/
# ---------------------------------------------------------------------------
CODECHEF_API_KEY=
CODECHEF_API_SECRET=

# ---------------------------------------------------------------------------
# CORS - frontend dev server
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
